{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://llux.org/frontmatter.schema.json",
  "title": "Llux Frontmatter Specification",
  "description": "Optional vocabulary rules for Llux Markdown frontmatter blocks. No fields are required.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference endpoint for machine-validation. Optional."
    },
    "title": {
      "type": "string",
      "maxLength": 120,
      "description": "Human-readable name of the module/page. Recommended but not required."
    },
    "type": {
      "type": "string",
      "enum": ["component", "layout", "view", "guide", "intent", "contract", "idea", "note"],
      "description": "The document type. Recommended but not required."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic versioning for the document. Recommended for formal documents."
    },
    "author": {
      "type": "string",
      "description": "Creator of the document. Optional."
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation. Optional."
    },
    "modified": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last modification. Optional."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "published", "archived"],
      "description": "Document lifecycle status. Optional."
    },
    "ai_optimized": {
      "type": "boolean",
      "default": true,
      "description": "Indicates if the document is structured for AI consumption. Optional. Defaults to true."
    }
  },
  "required": [],
  "additionalProperties": true,
  "patternProperties": {
    "^x-": {
      "type": "object",
      "description": "Vendor-specific extensions (OpenAPI-style x-prefix). Optional."
    }
  }
}
